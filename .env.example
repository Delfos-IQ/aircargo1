# Copy this file to .env and fill in the real values
# NEVER commit the .env file to GitHub

# ── Firebase ────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Cloudflare Worker (email notifications) ─────────────────
# Leave empty to disable notifications (app works normally without them)
VITE_WORKER_URL=https://acrosscargo-notifications.<your-subdomain>.workers.dev
VITE_WORKER_SECRET=your_shared_secret_here   # must match WORKER_SECRET wrangler secret
